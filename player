ENEMY.CS

using System;

public abstract class Enemy : Character
{
    // Private fields for enemy-specific data
    protected string enemyType;
    protected int rewardExperience;
    
    // Properties
    public string EnemyType 
    { 
        get { return enemyType; } 
        protected set { enemyType = value; } 
    }
    
    public int RewardExperience 
    { 
        get { return rewardExperience; } 
        protected set { rewardExperience = value; } 
    }
    
    // Constructor
    public Enemy(string name, int maxHealth, int attack, int defense, string type, int rewardExp) 
        : base(name, maxHealth, attack, defense)
    {
        enemyType = type;
        rewardExperience = rewardExp;
    }
    
    // Abstract method for enemy AI decision making
    public abstract int DecideAction();
    
    // Abstract method for special ability
    public abstract void UseSpecialAbility(Character target);
    
    // Override PerformAction
    public override void PerformAction()
    {
        Console.WriteLine($"{Name} the {enemyType} growls menacingly!");
    }
    
    // Override DisplayStats
    public override void DisplayStats()
    {
        Console.WriteLine($"\n========== {Name.ToUpper()} ==========");
        Console.WriteLine($"Type: {enemyType}");
        Console.WriteLine($"HP: {Health}/{MaxHealth}");
        Console.WriteLine($"ATK: {Attack}");
        Console.WriteLine($"DEF: {Defense}");
        Console.WriteLine($"Reward: {rewardExperience} XP");
        Console.WriteLine("===================================");
    }
}

